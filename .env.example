# Twelve-Factor: configuração via variáveis de ambiente (nunca commitar .env)

# Raiz do projeto (opcional; padrão = diretório do pyproject.toml)
# Em Docker Compose use PROJECT_ROOT=/app (já definido no compose)
# PROJECT_ROOT=C:\Users\bruno.silva\Downloads\TechChallenger Fase 5\Projeto Python com Docker

# Kaggle API (obrigatório para download do dataset)
KAGGLE_USERNAME=seu_usuario
KAGGLE_KEY=sua_chave_api

# OpenAI (obrigatório para análise STRIDE)
OPENAI_API_KEY=sk-...

# Parâmetros opcionais
MAX_IMAGENS=10
SHARPNESS_THRESHOLD=150.0
KAGGLE_DATASET=carlosrian/software-architecture-dataset
OPENAI_MODEL=gpt-4o
